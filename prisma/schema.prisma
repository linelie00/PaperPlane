// PaperPlane MVP Prisma schema
// 기준 문서: docs/05_DB_SCHEMA.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TranslationStatus {
  pending
  processing
  completed
  failed
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String? // 소셜 전용 계정은 비밀번호가 없다.
  nickname      String
  image         String? // 프로필 사진 (선택)
  coverImage    String? // 작가 홈 배경 사진 (선택)
  bio           String? // 작가 소개 (선택)
  emailVerified DateTime? // null = 미인증
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  works         Work[]
  accounts      OAuthAccount[]
  verificationTokens EmailVerificationToken[]
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String // "google" | "kakao" | "naver"
  providerAccountId String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique // 원본 토큰은 메일 링크로만 전달, DB엔 SHA-256 해시 저장
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Work {
  id             String       @id @default(cuid())
  authorId       String
  title          String
  description    String       @default("")
  genre          String       @default("")
  tags           String[]     @default([])
  sourceLanguage String       @default("ko")
  targetLanguage String       @default("en")
  isPublic       Boolean      @default(false)
  publicSlug     String?      @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  chapters       Chapter[]
  comments       Comment[]
  viewLogs       ViewLog[]

  @@index([authorId])
}

model Chapter {
  id                String            @id @default(cuid())
  workId            String
  order             Int // 회차 번호 (1부터)
  title             String
  originalText      String
  translatedText    String?
  translationStatus TranslationStatus @default(pending)
  isPublic          Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  work              Work              @relation(fields: [workId], references: [id], onDelete: Cascade)
  comments          Comment[]

  @@unique([workId, order])
  @@index([workId])
}

model Comment {
  id                 String    @id @default(cuid())
  workId             String
  chapterId          String? // 회차별 댓글 (null = 작품 단위 레거시)
  parentId           String? // 대댓글이면 부모 댓글 id
  nickname           String
  content            String
  deletePasswordHash String? // 익명 작성자가 본인 댓글을 삭제할 때 사용
  createdAt          DateTime  @default(now())
  work               Work      @relation(fields: [workId], references: [id], onDelete: Cascade)
  chapter            Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  parent             Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies            Comment[] @relation("CommentReplies")

  @@index([workId])
  @@index([chapterId])
  @@index([parentId])
}

model ViewLog {
  id          String   @id @default(cuid())
  workId      String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  userAgent   String?
  ipHash      String?
  createdAt   DateTime @default(now())
  work        Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@index([createdAt])
}
