// PaperPlane MVP Prisma schema
// 기준 문서: docs/05_DB_SCHEMA.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // 런타임 연결 (Neon 등 서버리스에서는 풀링된 URL 권장)
  url       = env("DATABASE_URL")
  // 마이그레이션/db push용 직접 연결 (없으면 DATABASE_URL과 동일하게 두면 됨)
  directUrl = env("DIRECT_URL")
}

enum TranslationStatus {
  pending
  processing
  completed
  failed
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String? // 소셜 전용 계정은 비밀번호가 없다.
  nickname      String
  image         String? // 프로필 사진 (선택)
  coverImage    String? // 작가 홈 배경 사진 (선택)
  bio           String? // 작가 소개 (선택)
  emailVerified DateTime? // null = 미인증
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  works         Work[]
  accounts      OAuthAccount[]
  verificationTokens EmailVerificationToken[]
  comments      Comment[] // 로그인 후 작성한 댓글
  links         AuthorLink[] // 작가 SNS 링크
  // 구독: subscriptions = 내가 구독한 작가, subscribers = 나를 구독한 독자
  subscriptions Subscription[] @relation("Subscriber")
  subscribers   Subscription[] @relation("Author")
  authorHearts  AuthorHeart[]  @relation("AuthorHeartUser") // 내가 누른 작가 하트
  authorHeartsReceived AuthorHeart[] @relation("AuthorHeartTarget") // 내가 받은 작가 하트
  workHearts    WorkHeart[] // 내가 누른 작품 하트
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String // "google" | "kakao" | "naver"
  providerAccountId String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique // 원본 토큰은 메일 링크로만 전달, DB엔 SHA-256 해시 저장
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Work {
  id             String       @id @default(cuid())
  authorId       String
  title          String
  description    String       @default("")
  genre          String       @default("")
  tags           String[]     @default([])
  sourceLanguage String       @default("ko")
  targetLanguage String       @default("en") // (구) 단일 번역 언어 — targetLanguages로 이관
  targetLanguages String[]    @default([]) // 번역 대상 언어 목록 (다국어)
  coverImage     String? // 작품 메인 이미지 (선택)
  isPublic       Boolean      @default(false)
  publicSlug     String?      @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  chapters       Chapter[]
  comments       Comment[]
  viewLogs       ViewLog[]
  hearts         WorkHeart[]

  @@index([authorId])
}

model Chapter {
  id                String            @id @default(cuid())
  workId            String
  order             Int // 정렬 순서 (1부터)
  title             String
  category          String? // 회차 종류(본편/외전/낙서/작업 비하인드 등, 선택)
  originalText      String
  translatedText    String? // (구) 단일 번역 — ChapterTranslation으로 이관
  translationStatus TranslationStatus @default(pending) // (구)
  coverImage        String? // 회차 메인 이미지 (선택)
  isPublic          Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  work              Work                 @relation(fields: [workId], references: [id], onDelete: Cascade)
  comments          Comment[]
  translations      ChapterTranslation[]

  @@unique([workId, order])
  @@index([workId])
}

model ChapterTranslation {
  id        String            @id @default(cuid())
  chapterId String
  language  String // "en" | "ja" | "zh" | "ko" 등
  text      String?
  status    TranslationStatus @default(pending)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  chapter   Chapter           @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, language])
  @@index([chapterId])
}

model Comment {
  id                 String    @id @default(cuid())
  workId             String
  chapterId          String? // 회차별 댓글 (null = 작품 단위 레거시)
  parentId           String? // 대댓글이면 부모 댓글 id
  userId             String? // 로그인 작성자 (null = 레거시 익명 댓글)
  nickname           String // 표시용 닉네임 스냅샷 (로그인 시 세션 닉네임)
  content            String
  deletePasswordHash String? // (레거시) 익명 작성자 본인 삭제용 — 신규 댓글은 미사용
  createdAt          DateTime  @default(now())
  work               Work      @relation(fields: [workId], references: [id], onDelete: Cascade)
  chapter            Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  parent             Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies            Comment[] @relation("CommentReplies")
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workId])
  @@index([chapterId])
  @@index([parentId])
  @@index([userId])
}

// 독자 → 작가 구독 (피드 반영). 하트와는 별개.
model Subscription {
  id           String   @id @default(cuid())
  subscriberId String // 구독하는 독자
  authorId     String // 구독 대상 작가
  createdAt    DateTime @default(now())
  subscriber   User     @relation("Subscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  author       User     @relation("Author", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, authorId])
  @@index([authorId])
}

// 작가 홈 하트 (가벼운 좋아요). 구독과는 별개.
model AuthorHeart {
  id        String   @id @default(cuid())
  userId    String // 하트를 누른 사람
  authorId  String // 대상 작가
  createdAt DateTime @default(now())
  user      User     @relation("AuthorHeartUser", fields: [userId], references: [id], onDelete: Cascade)
  author    User     @relation("AuthorHeartTarget", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([userId, authorId])
  @@index([authorId])
}

// 작품 하트
model WorkHeart {
  id        String   @id @default(cuid())
  userId    String
  workId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([workId])
}

// 작가 SNS 링크 (프로필에서 관리)
model AuthorLink {
  id        String      @id @default(cuid())
  userId    String
  platform  String // "twitter" | "instagram" | "youtube" 등 자유 라벨
  url       String
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks    LinkClick[]

  @@index([userId])
}

// SNS 링크 클릭 로그 (서비스 어필용 클릭률 지표)
model LinkClick {
  id        String     @id @default(cuid())
  linkId    String
  userId    String? // 로그인 상태면 기록 (익명 가능)
  ipHash    String?
  referrer  String?
  createdAt DateTime   @default(now())
  link      AuthorLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([createdAt])
}

model ViewLog {
  id          String   @id @default(cuid())
  workId      String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  userAgent   String?
  ipHash      String?
  createdAt   DateTime @default(now())
  work        Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@index([createdAt])
}
