# Database (PostgreSQL)
# 로컬: 로컬 Postgres. 배포(Vercel): Neon 등 클라우드 Postgres.
#   - DATABASE_URL : 런타임 연결 (Neon은 풀링된 URL 권장, host에 -pooler 포함)
#   - DIRECT_URL   : 마이그레이션/db push용 직접 연결 (로컬은 DATABASE_URL과 동일하게)
DATABASE_URL="postgresql://user:password@localhost:5432/paperplane"
DIRECT_URL="postgresql://user:password@localhost:5432/paperplane"

# 이미지 저장 (Vercel Blob)
# 로컬: 비워두면 public/uploads 디스크에 저장. 배포: Vercel Blob 스토어 연결 시 자동 주입됨.
BLOB_READ_WRITE_TOKEN=""

# Auth
AUTH_SECRET="change-this-to-a-long-random-secret"

# LLM (OpenAI 호환 chat/completions — 기본값은 Upstage Solar)
# 다른 제공자로 바꾸려면 BASE_URL / MODEL / API_KEY 세 값만 교체하면 된다.
#   Upstage Solar : https://api.upstage.ai/v1            모델 예) solar-pro2
#   Groq          : https://api.groq.com/openai/v1       모델 예) llama-3.3-70b-versatile
#   Gemini(호환)  : https://generativelanguage.googleapis.com/v1beta/openai  모델 예) gemini-2.0-flash
#   Ollama(로컬)  : http://localhost:11434/v1            모델 예) llama3.1
LLM_API_KEY="up_your-upstage-api-key"
LLM_BASE_URL="https://api.upstage.ai/v1"
LLM_MODEL="solar-pro2"

# OAuth (간편 로그인)
# 콜백 URL을 각 제공자 콘솔에 등록한다: ${NEXT_PUBLIC_APP_URL}/api/auth/oauth/{provider}/callback
#   예) http://localhost:3000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
KAKAO_CLIENT_ID=""          # Kakao REST API 키
KAKAO_CLIENT_SECRET=""      # Kakao 보안(client secret) 사용 시
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# 이메일 인증 (Resend 무료 티어 — https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="PaperPlane <onboarding@resend.dev>"   # 도메인 검증 전 테스트용 발신 주소

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
